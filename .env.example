# =============================================
#  POSTGRES
# =============================================
POSTGRES_USER=dentbot
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dentbot_db
POSTGRES_PORT=5432

# =============================================
#  N8N
# =============================================
# Gere uma chave segura com: openssl rand -hex 16
N8N_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_16
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_PORT=5678
# URL onde o n8n é acessível externamente
# Desenvolvimento local: http://localhost:5678
# Servidor com domínio: https://n8n.seudominio.com
WEBHOOK_URL=http://localhost:5678

# =============================================
#  EVOLUTION API
# =============================================
EVOLUTION_API_KEY=CHANGE_ME
EVOLUTION_PORT=8080

# =============================================
#  REDIS
# =============================================
REDIS_PORT=6379
